// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  TOURNAMENT_ADMIN
  SCORER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  PAUSED
  COMPLETED
  ABANDONED
}

enum InningsStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum DismissalType {
  BOWLED
  CAUGHT
  CAUGHT_AND_BOWLED
  LBW
  RUN_OUT
  STUMPED
  HIT_WICKET
  RETIRED
  OTHER
}

model User {
  id        String     @id @default(uuid())
  phone     String     @unique
  name      String?
  role      UserRole   @default(VIEWER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  createdTournaments Tournament[] @relation("TournamentCreatedBy")
  scoredBallEvents   BallEvent[]  @relation("BallEventScorer")

  @@map("users")
}

model Tournament {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User    @relation("TournamentCreatedBy", fields: [createdById], references: [id])
  teams     Team[]
  matches   Match[]

  @@map("tournaments")
}

model Team {
  id           String   @id @default(uuid())
  tournamentId String
  name         String
  shortName    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players        Player[]
  homeMatches    Match[]    @relation("HomeTeam")
  awayMatches    Match[]    @relation("AwayTeam")
  battingInnings Innings[]  @relation("BattingTeam")
  bowlingInnings Innings[]  @relation("BowlingTeam")

  @@unique([tournamentId, name])
  @@map("teams")
}

model Player {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  strikerEvents    BallEvent[] @relation("BallEventStriker")
  nonStrikerEvents BallEvent[] @relation("BallEventNonStriker")
  bowlerEvents     BallEvent[] @relation("BallEventBowler")
  fielderEvents    BallEvent[] @relation("BallEventFielder")
  outEvents        BallEvent[] @relation("BallEventPlayerOut")
  matchStats       MatchPlayerStat[]
  careerStat       PlayerCareerStat?

  @@unique([teamId, name])
  @@map("players")
}

model Match {
  id           String      @id @default(uuid())
  tournamentId String
  homeTeamId   String
  awayTeamId   String
  overs        Int
  venue        String?
  status       MatchStatus @default(SCHEDULED)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tournament    Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam      Team                @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team                @relation("AwayTeam", fields: [awayTeamId], references: [id])
  innings       Innings[]
  scoreSnapshot MatchScoreSnapshot?
  playerStats   MatchPlayerStat[]

  @@map("matches")
}

model Innings {
  id            String        @id @default(uuid())
  matchId       String
  battingTeamId String
  bowlingTeamId String
  inningsNumber Int
  status        InningsStatus @default(NOT_STARTED)
  runs          Int           @default(0)
  wickets       Int           @default(0)
  legalBalls    Int           @default(0)
  extras        Int           @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  match       Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  battingTeam Team        @relation("BattingTeam", fields: [battingTeamId], references: [id])
  bowlingTeam Team        @relation("BowlingTeam", fields: [bowlingTeamId], references: [id])
  ballEvents  BallEvent[]

  @@unique([matchId, inningsNumber])
  @@map("innings")
}

model BallEvent {
  id              String         @id @default(uuid())
  inningsId       String
  sequence        Int
  overNumber      Int
  ballInOver      Int
  strikerId       String
  nonStrikerId    String
  bowlerId        String
  fielderId       String?
  scoredById      String
  runsBat         Int            @default(0)
  wides           Int            @default(0)
  noBalls         Int            @default(0)
  byes            Int            @default(0)
  legByes         Int            @default(0)
  penaltyRuns     Int            @default(0)
  isLegalDelivery Boolean        @default(true)
  isWicket        Boolean        @default(false)
  dismissalType   DismissalType?
  playerOutId     String?
  notes           String?
  idempotencyKey  String         @unique
  createdAt       DateTime       @default(now())

  innings    Innings @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  striker    Player  @relation("BallEventStriker", fields: [strikerId], references: [id])
  nonStriker Player  @relation("BallEventNonStriker", fields: [nonStrikerId], references: [id])
  bowler     Player  @relation("BallEventBowler", fields: [bowlerId], references: [id])
  fielder    Player? @relation("BallEventFielder", fields: [fielderId], references: [id])
  scoredBy   User    @relation("BallEventScorer", fields: [scoredById], references: [id])
  playerOut  Player? @relation("BallEventPlayerOut", fields: [playerOutId], references: [id])

  @@unique([inningsId, sequence])
  @@map("ball_events")
}

model MatchScoreSnapshot {
  id           String   @id @default(uuid())
  matchId      String   @unique
  summary      String
  currentScore String
  payload      Json
  updatedAt    DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("match_score_snapshots")
}

model MatchPlayerStat {
  id             String   @id @default(uuid())
  matchId        String
  playerId       String
  matches        Int      @default(1)
  battingInnings Int      @default(0)
  bowlingInnings Int      @default(0)
  runs           Int      @default(0)
  ballsFaced     Int      @default(0)
  fours          Int      @default(0)
  sixes          Int      @default(0)
  outs           Int      @default(0)
  wickets        Int      @default(0)
  ballsBowled    Int      @default(0)
  runsConceded   Int      @default(0)
  catches        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@map("match_player_stats")
}

model PlayerCareerStat {
  id             String   @id @default(uuid())
  playerId       String   @unique
  matches        Int      @default(0)
  battingInnings Int      @default(0)
  bowlingInnings Int      @default(0)
  runs           Int      @default(0)
  ballsFaced     Int      @default(0)
  fours          Int      @default(0)
  sixes          Int      @default(0)
  outs           Int      @default(0)
  highestScore   Int      @default(0)
  wickets        Int      @default(0)
  ballsBowled    Int      @default(0)
  runsConceded   Int      @default(0)
  catches        Int      @default(0)
  updatedAt      DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_career_stats")
}
